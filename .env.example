# Copy to .env and adjust. Used by docker-compose.yml.
#
# Replace 192.168.1.50 with your Linux host's LAN IP (run `hostname -I`).
# The browser must be able to reach the backend at this address, so it CANNOT
# be localhost when you open the dashboard from another machine.

# --- URLs (browser-facing) ---
NEXT_PUBLIC_API_BASE_URL=http://192.168.1.50:4000
MC_DASH_FRONTEND_ORIGIN=http://192.168.1.50:3000

# --- Data ---
# Absolute path on the host where SQLite + server packs live. Created on first
# run. Must be absolute (the backend mounts it into MC containers by this path).
MC_DASH_DATA_DIR=/opt/mc-dash/data
# User the spawned Minecraft containers run as. Leave empty to match the backend
# (root under compose), which keeps server files readable for snapshots. Set to
# a uid:gid (e.g. 1000:1000) to run servers un-privileged instead.
# MC_CONTAINER_USER=

# --- Auth ---
# Set a password to require login. Generate a long random session secret, e.g.
#   openssl rand -hex 32
MC_DASH_PASSWORD=change-me
MC_DASH_SESSION_SECRET=replace-with-openssl-rand-hex-32
# Keep false for plain HTTP on a LAN (true would drop the cookie over http).
MC_DASH_COOKIE_SECURE=false

# --- Server ports ---
MC_SERVER_PORT_MIN=25565
MC_SERVER_PORT_MAX=25665

# --- Optional wildcard-subdomain router ---
MC_ROUTER_ENABLED=false
MC_ROUTER_DOMAIN=mc.example.com
MC_ROUTER_PORT=25565
