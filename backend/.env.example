# Server
PORT=4000

# Data store
SQLITE_PATH=./data/mc-dash.sqlite
DATA_ROOT=./data

# Java runtime image (pick 8-jre for older Forge packs)
JAVA_IMAGE=eclipse-temurin:17-jre
# User the per-server Minecraft containers run as. Leave unset to mirror the
# backend process (so world files stay readable by MC Dash for snapshots).
# Set "root" only if a pack needs to install packages at runtime (needs root).
# MC_CONTAINER_USER=1000:1000
# Default exposed server port (host)
MC_SERVER_PORT=25565
# Auto-assign port range (inclusive)
MC_SERVER_PORT_MIN=25565
MC_SERVER_PORT_MAX=25665

# Subdomain router (wildcard DNS -> per-server subdomains)
# Enable to accept connections on MC_ROUTER_PORT and route by hostname.
MC_ROUTER_ENABLED=false
# Base domain for servers (e.g., server1.<domain>)
MC_ROUTER_DOMAIN=mc.example.com
# Port the router listens on (usually 25565)
MC_ROUTER_PORT=25565
# Host to forward traffic to (where server ports are bound)
MC_ROUTER_TARGET_HOST=127.0.0.1
# Optional default subdomain for mc.example.com or unknown hostnames
# MC_ROUTER_DEFAULT_SUBDOMAIN=default

# Auth
# Set a password to require login on all mutating/server endpoints.
# Leave unset to run without auth (not recommended outside localhost).
# MC_DASH_PASSWORD=change-me
# Secret used to sign session cookies. Set a long random value so sessions
# survive restarts; if unset a random per-boot secret is used.
# MC_DASH_SESSION_SECRET=
# Comma-separated allowed frontend origins for credentialed CORS.
# MC_DASH_FRONTEND_ORIGIN=http://localhost:3000
# Session lifetime in days (default 7).
# MC_DASH_SESSION_TTL_DAYS=7
# Set true when serving over HTTPS so the session cookie gets the Secure flag.
# MC_DASH_COOKIE_SECURE=false

# Docker connection (use either socket or host)
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# DOCKER_HOST=tcp://127.0.0.1:2375
# DOCKER_TLS_VERIFY=0
# Override Docker API version if needed (otherwise dockerode negotiates)
# DOCKER_API_VERSION=1.44
